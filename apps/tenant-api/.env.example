# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=haruos
DB_PASSWORD=haruos
DB_DATABASE=haruos_tenant

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# AWS
AWS_REGION=ap-northeast-2

# S3
S3_BUCKET_NAME=haruos-dev-documents
