# =============================================================
# HaruOS 환경변수 — 단일 진실 공급원 (SSOT)
#
# 이 루트 .env 하나가 유일한 환경변수 소스다.
#   - Docker:  compose 가 env_file 로 읽어 ${VAR} 보간 + 컨테이너에 주입
#   - 로컬:    dotenv-cli 가 읽어 NestJS process.env 로 주입 (pnpm dev:*)
#   - Vite:    vite.config 의 loadEnv 가 이 파일에서 VITE_* 로드
#
# 사용: cp .env.example .env  (또는 make env)
# 주의: .env 는 커밋하지 않는다. 비밀값은 각자/배포 시 채운다.
# =============================================================

# -- 공통: 실행 환경 --
NODE_ENV=development

# -- 게이트웨이 (개발 진입 포트) --
# 협업 표준(make up)에서 *.haruos.localhost:HTTP_PORT 로 접속. HMR clientPort 정합에도 사용.
HTTP_PORT=80

# -- 데이터베이스 (공통 자격) --
# 로컬 직접 실행 기준값. Docker 에서는 compose 가 DB_HOST=postgres 등으로 덮어쓴다.
# DB 이름/포트(앱별 상이)는 각 앱 기본값(console=haruos_console / tenant=haruos_tenant)을 따른다.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=haruos
DB_PASSWORD=haruos

# compose 전용 (postgres 컨테이너 초기화 + Flyway). 위 DB_USERNAME/PASSWORD 와 같은 값 유지.
POSTGRES_USER=haruos
POSTGRES_PASSWORD=haruos
CONSOLE_DB_NAME=haruos_console
TENANT_DB_NAME=haruos_tenant

# -- JWT --
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -- API 포트 (compose 가 각 컨테이너 PORT 로 주입) --
CONSOLE_API_PORT=3000
TENANT_API_PORT=3001

# -- CORS (게이트웨이 도메인) --
CORS_ORIGIN=http://console.haruos.localhost
TENANT_CORS_ORIGIN=http://tenant.haruos.localhost

# -- AWS / Bedrock (tenant-api) --
AWS_REGION=ap-northeast-2
# S3_BUCKET_NAME=
# BEDROCK_PRIMARY_MODEL_ID=
# BEDROCK_FALLBACK_MODEL_ID=
# BEDROCK_EMBEDDING_MODEL_ID=

# -- ClickUp (tenant-api) --
# CLICKUP_API_TOKEN=
# CLICKUP_TEAM_ID=
CLICKUP_WEBHOOK_SECRET=

# -- Stripe (console-api) --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# -- Vite (프론트엔드, 빌드/런타임에 정적 주입) --
# 게이트웨이 경유 HMR 웹소켓 포트. HTTP_PORT 와 맞춘다.
VITE_HMR_PORT=80
# API 베이스 URL. 게이트웨이가 /api 를 프록시하므로 비워두면 same-origin 사용.
VITE_API_URL=
