# =============================================================
# HaruOS Docker 환경변수 (docker-compose.yml / docker-compose.dev.yml 공용)
# 사용법: cp .env.example .env 후 값 수정
# =============================================================

# -- PostgreSQL --
POSTGRES_USER=haruos
POSTGRES_PASSWORD=change-me-in-production
CONSOLE_DB_NAME=haruos_console
TENANT_DB_NAME=haruos_tenant

# -- JWT --
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -- Gateway --
# 게이트웨이 외부 노출 포트. *.haruos.localhost:HTTP_PORT 로 접속.
# HMR clientPort 정합에도 사용. 80 이 막혀 있으면 8080 등으로 바꾼다.
HTTP_PORT=80

# -- Console API --
CONSOLE_API_PORT=3000
CORS_ORIGIN=http://console.haruos.localhost

# -- Tenant API --
TENANT_API_PORT=3001
TENANT_CORS_ORIGIN=http://tenant.haruos.localhost
AWS_REGION=ap-northeast-2

# -- Stripe (console-api) --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# -- ClickUp (tenant-api) --
CLICKUP_WEBHOOK_SECRET=

# 참고: 웹(Vite) 내부 포트는 5173/5174 로 고정이며 게이트웨이가 프록시한다.
# 외부에서 포트로 직접 접근하지 않는다 (Host 헤더 기반 라우팅).
