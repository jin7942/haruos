# =============================================================
# HaruOS Docker 환경변수 (docker-compose.yml / docker-compose.dev.yml 공용)
# 사용법: cp .env.example .env 후 값 수정
# =============================================================

# -- PostgreSQL --
POSTGRES_USER=haruos
POSTGRES_PASSWORD=change-me-in-production
CONSOLE_DB_NAME=haruos_console
TENANT_DB_NAME=haruos_tenant

# -- JWT --
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# -- Console API --
CONSOLE_API_PORT=3000
CORS_ORIGIN=http://localhost:5173

# -- Tenant API --
TENANT_API_PORT=3001
AWS_REGION=ap-northeast-2

# -- Stripe (console-api) --
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# -- ClickUp (tenant-api) --
CLICKUP_WEBHOOK_SECRET=

# -- Console Web --
CONSOLE_WEB_PORT=5173

# -- Tenant Web --
TENANT_WEB_PORT=5174
